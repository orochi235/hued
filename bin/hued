#!/usr/bin/env bash
# hued — manage terminal colors per directory

set -euo pipefail

_hued_find() {
  local dir="$PWD"
  while [[ "$dir" != / && -n "$dir" ]]; do
    [[ -f "$dir/.hued" ]] && echo "$dir/.hued" && return 0
    dir="${dir%/*}"
  done
  return 1
}

_hued_set_key() {
  local key="$1" color="$2"
  if [[ -f .hued ]]; then
    grep -v "^${key}=" .hued > .hued.tmp
    echo "${key}=${color}" >> .hued.tmp
    mv .hued.tmp .hued
  else
    printf "# https://github.com/orochi235/hued\n${key}=%s\n" "$color" > .hued
  fi
  echo "Set ${key} to ${color} in ${PWD}/.hued"
}

case "${1:-}" in
  "")
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    grep '^background=\|^foreground=' "$file"
    ;;

  where)
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    echo "$file"
    ;;

  set)
    case "${2:-}" in
      bg|background)
        [[ -z "${3:-}" ]] && { echo "Usage: hued set bg <color>" >&2; exit 1; }
        _hued_set_key "background" "$3"
        ;;
      fg|foreground)
        [[ -z "${3:-}" ]] && { echo "Usage: hued set fg <color>" >&2; exit 1; }
        _hued_set_key "foreground" "$3"
        ;;
      *)
        [[ -z "${2:-}" ]] && { echo "Usage: hued set [bg|fg] <color>" >&2; exit 1; }
        _hued_set_key "background" "$2"
        ;;
    esac
    ;;

  *)
    echo "Usage: hued [where | set [bg|fg] <color>]" >&2
    exit 1
    ;;
esac
