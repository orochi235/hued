#!/usr/bin/env bash
# hued — manage terminal colors per directory

set -euo pipefail

_HUED_DIR="$(cd "$(dirname "$0")/.." && pwd)"

_hued_find() {
  local dir="$PWD"
  while [[ "$dir" != / && -n "$dir" ]]; do
    [[ -f "$dir/.hued" ]] && echo "$dir/.hued" && return 0
    dir="${dir%/*}"
  done
  return 1
}

_hued_normalize_color() {
  local bare="${1#\#}"

  # Expand 3-char shorthand to 6-char
  if [[ "$bare" =~ ^[0-9a-fA-F]{3}$ ]]; then
    bare="${bare:0:1}${bare:0:1}${bare:1:1}${bare:1:1}${bare:2:1}${bare:2:1}"
  fi

  # 6-char hex — normalize to lowercase #rrggbb
  if [[ "$bare" =~ ^[0-9a-fA-F]{6}$ ]]; then
    printf '#%s' "${bare,,}"
    return
  fi

  # Named color — resolve via hued-names.sh
  local names_file="$_HUED_DIR/hued-names.sh"
  if [[ -f "$names_file" ]]; then
    local hex
    hex=$(grep -m1 "\[${bare}\]=" "$names_file" 2>/dev/null | cut -d= -f2)
    [[ -n "$hex" ]] && printf '%s' "$hex" && return
  fi

  printf '%s' "$1"
}

_hued_parse_amount() {
  local val="$1"
  if [[ "$val" =~ ^([0-9]+(\.[0-9]+)?)%$ ]]; then
    awk -v n="${BASH_REMATCH[1]}" 'BEGIN{printf "%g", n/100}'
  else
    printf '%s' "$val"
  fi
}

_hued_parse_degrees() {
  local val="${1%deg}"
  val="${val%°}"
  printf '%s' "$val"
}

_hued_read_stdin_color() {
  [[ -t 0 ]] && return 1
  local line
  IFS= read -r line || return 1
  line="${line//[[:space:]]/}"
  [[ -z "$line" ]] && return 1
  printf '%s' "$line"
}

_hued_set_key() {
  local key="$1" color
  color="$(_hued_normalize_color "$2")"
  if [[ -f .hued ]]; then
    grep -v "^${key}=" .hued > .hued.tmp || true
    echo "${key}=${color}" >> .hued.tmp
    mv .hued.tmp .hued
  else
    printf "# https://github.com/orochi235/hued\n${key}=%s\n" "$color" > .hued
  fi
  echo "Set ${key} to ${color} in ${PWD}/.hued"
}

case "${1:-}" in
  "")
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    grep '^background=\|^foreground=' "$file"
    ;;

  where)
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    echo "$file"
    ;;

  resolve)
    [[ -z "${2:-}" ]] && { echo "Usage: hued resolve <color>" >&2; exit 1; }
    command -v pastel >/dev/null 2>&1 || {
      echo "hued resolve: requires 'pastel' (brew install pastel)" >&2
      exit 1
    }
    pastel format hex "$2"
    ;;

  get)
    case "${2:-}" in
      bg|background) key="background" ;;
      fg|foreground) key="foreground" ;;
      *) echo "Usage: hued get [bg|fg]" >&2; exit 1 ;;
    esac
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    raw=$({ grep -m1 "^${key}=" "$file" || true; } | cut -d= -f2 | tr -d '[:space:]')
    [[ -z "$raw" ]] && exit 1
    command -v pastel >/dev/null 2>&1 || {
      echo "hued get: requires 'pastel' (brew install pastel)" >&2
      exit 1
    }
    pastel format hex "$raw"
    ;;

  mod|adjust)
    case "${2:-}" in
      bg|background) key="background" ;;
      fg|foreground) key="foreground" ;;
      *) echo "Usage: hued mod [bg|fg] <op> [<args>...]" >&2; exit 1 ;;
    esac
    op="${3:-}"
    [[ -z "$op" ]] && { echo "Usage: hued mod $2 <op> [<args>...]" >&2; exit 1; }
    command -v pastel >/dev/null 2>&1 || {
      echo "hued mod: requires 'pastel' (brew install pastel)" >&2
      exit 1
    }
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    current=$({ grep -m1 "^${key}=" "$file" || true; } | cut -d= -f2 | tr -d '[:space:]')
    [[ -z "$current" ]] && { echo "hued mod: ${key} not set in $file" >&2; exit 1; }
    case "$op" in
      darken|lighten|saturate|desaturate)
        amount="${4:-}"
        [[ -z "$amount" ]] && { echo "Usage: hued mod $2 $op <amount|percent>" >&2; exit 1; }
        amount="$(_hued_parse_amount "$amount")"
        new=$(pastel "$op" "$amount" "$current" | pastel format hex) || exit 1
        ;;
      rotate)
        [[ -z "${4:-}" ]] && { echo "Usage: hued mod $2 rotate <degrees>" >&2; exit 1; }
        degrees="$(_hued_parse_degrees "$4")"
        new=$(pastel rotate "$degrees" "$current" | pastel format hex) || exit 1
        ;;
      complement|to-gray)
        new=$(pastel "$op" "$current" | pastel format hex) || exit 1
        ;;
      mix)
        other="${4:-}"
        [[ -z "$other" ]] && { echo "Usage: hued mod $2 mix <other-color> [<ratio>]" >&2; exit 1; }
        ratio="$(_hued_parse_amount "${5:-0.5}")"
        new=$(pastel mix --fraction "$ratio" "$other" "$current" | pastel format hex) || exit 1
        ;;
      *)
        echo "hued mod: unknown op '$op' (darken, lighten, saturate, desaturate, rotate, complement, to-gray, mix)" >&2
        exit 1
        ;;
    esac
    _hued_set_key "$key" "$new"
    ;;

  set)
    case "${2:-}" in
      bg|background)
        color="${3:-}"
        [[ -z "$color" ]] && { color="$(_hued_read_stdin_color)" || color=""; }
        [[ -z "$color" ]] && { echo "Usage: hued set bg <color>" >&2; exit 1; }
        _hued_set_key "background" "$color"
        ;;
      fg|foreground)
        color="${3:-}"
        [[ -z "$color" ]] && { color="$(_hued_read_stdin_color)" || color=""; }
        [[ -z "$color" ]] && { echo "Usage: hued set fg <color>" >&2; exit 1; }
        _hued_set_key "foreground" "$color"
        ;;
      "")
        color="$(_hued_read_stdin_color)" || color=""
        [[ -z "$color" ]] && { echo "Usage: hued set [bg|fg] <color>" >&2; exit 1; }
        _hued_set_key "background" "$color"
        ;;
      *)
        _hued_set_key "background" "$2"
        ;;
    esac
    ;;

  unset)
    case "${2:-}" in
      bg|background) key="background" ;;
      fg|foreground) key="foreground" ;;
      *) echo "Usage: hued unset [bg|fg]" >&2; exit 1 ;;
    esac
    [[ -f .hued ]] || { echo "hued unset: no .hued in ${PWD}" >&2; exit 1; }
    if ! grep -q "^${key}=" .hued; then
      echo "hued unset: ${key} not set in ${PWD}/.hued" >&2
      exit 1
    fi
    grep -v "^${key}=" .hued > .hued.tmp || true
    mv .hued.tmp .hued
    echo "Unset ${key} in ${PWD}/.hued"
    ;;

  pack)
    shift
    dir="."
    if [[ -n "${1:-}" && "$1" != -* ]]; then
      dir="$1"
      shift
    fi
    dir="$(cd "$dir" && pwd)"
    output=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -o) output="${2:-}"; shift 2 ;;
        *) echo "Usage: hued pack [<dir>] [-o <file>]" >&2; exit 1 ;;
      esac
    done
    result=$(python3 - "$dir" <<'PYEOF'
import os, json, sys

root_dir = sys.argv[1]
result = {}
for dirpath, _, files in os.walk(root_dir):
    if '.hued' in files:
        config = {}
        with open(os.path.join(dirpath, '.hued')) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith('#'):
                    continue
                if '=' in line:
                    k, v = line.split('=', 1)
                    config[k.strip()] = v.strip()
        if config:
            result[dirpath] = config
print(json.dumps(result, indent=2))
PYEOF
)
    if [[ -n "$output" ]]; then
      echo "$result" > "$output"
      echo "Wrote $(echo "$result" | python3 -c 'import json,sys; print(len(json.load(sys.stdin)))') entries to $output"
    else
      echo "$result"
    fi
    ;;

  unpack)
    [[ -z "${2:-}" ]] && { echo "Usage: hued unpack <file> [--force]" >&2; exit 1; }
    file="$2"
    force=0
    [[ "${3:-}" == "--force" ]] && force=1
    python3 - "$file" "$force" <<'PYEOF'
import os, json, sys

file, force = sys.argv[1], sys.argv[2] == '1'
with open(file) as f:
    data = json.load(f)

for dirpath, config in data.items():
    hued_path = os.path.join(dirpath, '.hued')
    if os.path.exists(hued_path) and not force:
        print(f'Skipping {hued_path} (already exists, use --force to overwrite)', file=sys.stderr)
        continue
    os.makedirs(dirpath, exist_ok=True)
    with open(hued_path, 'w') as f:
        f.write('# https://github.com/orochi235/hued\n')
        for k, v in config.items():
            f.write(f'{k}={v}\n')
    print(f'Wrote {hued_path}')
PYEOF
    ;;

  -i|--interactive)
    _picker="$(dirname "$0")/hued-pick"
    if [[ ! -f "$_picker" ]]; then
      echo "hued -i: hued-pick not found at $_picker" >&2
      exit 1
    fi
    _current_bg=""
    _current_fg=""
    if _file=$(_hued_find 2>/dev/null); then
      _raw_bg=$({ grep -m1 '^background=' "$_file" || true; } | cut -d= -f2 | tr -d '[:space:]')
      _raw_fg=$({ grep -m1 '^foreground=' "$_file" || true; } | cut -d= -f2 | tr -d '[:space:]')
      [[ -z "$_raw_bg" ]] || _current_bg=$(_hued_normalize_color "$_raw_bg")
      [[ -z "$_raw_fg" ]] || _current_fg=$(_hued_normalize_color "$_raw_fg")
    fi
    _live_flag=""
    for _arg in "$@"; do [[ "$_arg" == "--live" ]] && _live_flag="--live" && break; done
    _tmpfile=$(mktemp)
    "$_picker" \
      ${_current_bg:+--bg "$_current_bg"} \
      ${_current_fg:+--fg "$_current_fg"} \
      ${_live_flag:+"$_live_flag"} --output "$_tmpfile" || { rm -f "$_tmpfile"; exit 0; }
    while IFS='=' read -r _key _value; do
      case "$_key" in
        background) _hued_set_key "background" "$_value" ;;
        foreground) _hued_set_key "foreground" "$_value" ;;
      esac
    done < "$_tmpfile"
    rm -f "$_tmpfile"
    ;;

  *)
    echo "Usage: hued [where | get [bg|fg] | set [bg|fg] <color> | unset [bg|fg] | mod [bg|fg] <op> [<args>...] | resolve <color> | pack [<dir>] [-o <file>] | unpack <file> [--force] | -i [--live]]" >&2
    exit 1
    ;;
esac
