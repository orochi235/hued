#!/usr/bin/env bash
# hued — manage terminal background colors per directory

set -euo pipefail

_hued_find() {
  local dir="$PWD"
  while [[ "$dir" != / && -n "$dir" ]]; do
    [[ -f "$dir/.hued" ]] && echo "$dir/.hued" && return 0
    dir="${dir%/*}"
  done
  return 1
}

case "${1:-}" in
  "")
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    grep -m1 '^background=' "$file" | cut -d= -f2 | tr -d '[:space:]'
    ;;

  where)
    file=$(_hued_find) || { echo "No .hued file found" >&2; exit 1; }
    echo "$file"
    ;;

  set)
    [[ -z "${2:-}" ]] && { echo "Usage: hued set <color>" >&2; exit 1; }
    color="$2"
    if [[ -f .hued ]]; then
      # Update existing file, preserving comments and other lines
      grep -v '^background=' .hued > .hued.tmp
      echo "background=${color}" >> .hued.tmp
      mv .hued.tmp .hued
    else
      printf "# https://github.com/orochi235/hued\nbackground=%s\n" "$color" > .hued
    fi
    echo "Set background to ${color} in ${PWD}/.hued"
    ;;

  *)
    echo "Usage: hued [where | set <color>]" >&2
    exit 1
    ;;
esac
