#!/usr/bin/env bash
# termcolor — manage terminal background colors per directory

set -euo pipefail

_tc_find() {
  local dir="$PWD"
  while [[ "$dir" != / && -n "$dir" ]]; do
    [[ -f "$dir/.termcolor" ]] && echo "$dir/.termcolor" && return 0
    dir="${dir%/*}"
  done
  return 1
}

case "${1:-}" in
  "")
    file=$(_tc_find) || { echo "No .termcolor file found" >&2; exit 1; }
    grep -m1 '^background=' "$file" | cut -d= -f2 | tr -d '[:space:]'
    ;;

  where)
    file=$(_tc_find) || { echo "No .termcolor file found" >&2; exit 1; }
    echo "$file"
    ;;

  set)
    [[ -z "${2:-}" ]] && { echo "Usage: termcolor set <color>" >&2; exit 1; }
    color="$2"
    if [[ -f .termcolor ]]; then
      # Update existing file, preserving comments and other lines
      grep -v '^background=' .termcolor > .termcolor.tmp
      echo "background=${color}" >> .termcolor.tmp
      mv .termcolor.tmp .termcolor
    else
      printf "# https://github.com/orochi235/termcolor\nbackground=%s\n" "$color" > .termcolor
    fi
    echo "Set background to ${color} in ${PWD}/.termcolor"
    ;;

  *)
    echo "Usage: termcolor [where | set <color>]" >&2
    exit 1
    ;;
esac
